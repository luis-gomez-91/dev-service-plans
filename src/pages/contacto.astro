---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contacto" description="Contacta con Dev Service Plans. Formulario y WhatsApp en la página de inicio.">
  <div class="max-w-xl mx-auto py-16 text-center">
    <p class="text-neutral-600 dark:text-neutral-400 mb-4">Redirigiendo a la sección de contacto...</p>
    <a href="/#contacto" class="text-neutral-800 dark:text-neutral-200 font-medium underline">Ir a contacto</a>
  </div>
  <script>
    window.location.replace('/#contacto');
  </script>
</BaseLayout>
