---
import { Sun, Moon } from '@lucide/astro';
---

<button
  type="button"
  id="theme-toggle"
  aria-label="Cambiar tema (claro/oscuro)"
  class="theme-toggle-btn p-2 rounded-lg text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation"
>
  <span id="theme-icon-sun" aria-hidden="true" style="display: none;">
    <Sun size={20} strokeWidth={1.75} />
  </span>
  <span id="theme-icon-moon" aria-hidden="true" style="display: none;">
    <Moon size={20} strokeWidth={1.75} />
  </span>
</button>
