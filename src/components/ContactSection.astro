---
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? '';
---

<section id="contacto" class="scroll-mt-20 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 p-5 sm:p-6 lg:p-8 max-w-2xl mx-auto">
  <h2 class="text-xl sm:text-2xl font-bold text-neutral-900 dark:text-neutral-50 mb-1">
    Solicitar información
  </h2>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-6">
    ¿Tu empresa está interesada en un plan? Envíame un mensaje.
  </p>

  {formspreeId ? (
    <form
      action={`https://formspree.io/f/${formspreeId}`}
      method="POST"
      class="space-y-4"
    >
      <input type="hidden" name="_subject" value="[Dev Service Plans] Nueva solicitud de información" />
      <input type="hidden" name="_replyto" value="" id="contact-replyto" />
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Nombre *</span>
          <input
            type="text"
            name="nombre"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="Tu nombre"
          />
        </label>
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Email *</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            id="contact-email"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="tu@email.com"
          />
        </label>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Empresa</span>
          <input
            type="text"
            name="empresa"
            autocomplete="organization"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="Nombre de la empresa"
          />
        </label>
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Teléfono</span>
          <input
            type="tel"
            name="telefono"
            autocomplete="tel"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="+59 300 000 000"
          />
        </label>
      </div>
      <label class="block">
        <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Mensaje *</span>
        <textarea
          name="mensaje"
          required
          rows={4}
          class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500 resize-y min-h-[100px]"
          placeholder="Cuéntame en qué plan o servicio estás interesado..."
        />
      </label>
      <div class="flex flex-wrap gap-3 pt-2">
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-neutral-800 dark:bg-neutral-200 text-white dark:text-neutral-900 px-4 py-2.5 text-sm font-medium hover:bg-neutral-700 dark:hover:bg-neutral-300 transition-colors"
        >
          Enviar mensaje
        </button>
      </div>
    </form>
  ) : (
    <p class="text-sm text-amber-700 dark:text-amber-400">
      Configura <code class="bg-neutral-200 dark:bg-neutral-700 px-1 rounded">PUBLIC_FORMSPREE_ID</code> en tu <code>.env</code> para activar el envío por correo.
    </p>
  )}
</section>

<script>
  const replyTo = document.getElementById('contact-replyto') as HTMLInputElement | null;
  const emailInput = document.getElementById('contact-email') as HTMLInputElement | null;
  if (replyTo && emailInput) {
    emailInput.addEventListener('change', () => { replyTo.value = emailInput.value; });
    emailInput.addEventListener('input', () => { replyTo.value = emailInput.value; });
  }
</script>
