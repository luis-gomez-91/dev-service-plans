---
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? '';
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
const defaultWhatsAppMessage = 'Hola, me interesa solicitar información sobre los planes de desarrollo.';
const whatsappUrl = whatsappNumber
  ? `https://wa.me/${whatsappNumber.replace(/\D/g, '')}?text=${encodeURIComponent(defaultWhatsAppMessage)}`
  : '#';
---

<section id="contacto" class="scroll-mt-20 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 p-5 sm:p-6 lg:p-8 max-w-2xl mx-auto">
  <h2 class="text-xl sm:text-2xl font-bold text-neutral-900 dark:text-neutral-50 mb-1">
    Solicitar información
  </h2>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-6">
    ¿Tu empresa está interesada en un plan? Envíame un mensaje o escríbeme por WhatsApp.
  </p>

  {formspreeId ? (
    <form
      action={`https://formspree.io/f/${formspreeId}`}
      method="POST"
      class="space-y-4"
    >
      <input type="hidden" name="_subject" value="[Dev Service Plans] Nueva solicitud de información" />
      <input type="hidden" name="_replyto" value="" id="contact-replyto" />
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Nombre *</span>
          <input
            type="text"
            name="nombre"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="Tu nombre"
          />
        </label>
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Email *</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            id="contact-email"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="tu@email.com"
          />
        </label>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Empresa</span>
          <input
            type="text"
            name="empresa"
            autocomplete="organization"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="Nombre de la empresa"
          />
        </label>
        <label class="block sm:col-span-1">
          <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Teléfono</span>
          <input
            type="tel"
            name="telefono"
            autocomplete="tel"
            class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
            placeholder="+34 600 000 000"
          />
        </label>
      </div>
      <label class="block">
        <span class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Mensaje *</span>
        <textarea
          name="mensaje"
          required
          rows={4}
          class="w-full rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-900 px-3 py-2.5 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500 resize-y min-h-[100px]"
          placeholder="Cuéntame en qué plan o servicio estás interesado..."
        />
      </label>
      <div class="flex flex-wrap gap-3 pt-2">
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-neutral-800 dark:bg-neutral-200 text-white dark:text-neutral-900 px-4 py-2.5 text-sm font-medium hover:bg-neutral-700 dark:hover:bg-neutral-300 transition-colors"
        >
          Enviar mensaje
        </button>
        {whatsappNumber && (
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-[#25D366] text-white px-4 py-2.5 text-sm font-medium hover:bg-[#20BD5A] transition-colors"
            aria-label="Escribir por WhatsApp"
          >
            <span class="w-5 h-5 shrink-0" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </span>
            WhatsApp
          </a>
        )}
      </div>
    </form>
  ) : (
    <div class="space-y-4">
      <p class="text-sm text-amber-700 dark:text-amber-400">
        Configura <code class="bg-neutral-200 dark:bg-neutral-700 px-1 rounded">PUBLIC_FORMSPREE_ID</code> en tu <code>.env</code> para activar el envío por correo. Mientras tanto puedes usar WhatsApp:
      </p>
      {whatsappNumber ? (
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-[#25D366] text-white px-4 py-2.5 text-sm font-medium hover:bg-[#20BD5A] transition-colors"
          aria-label="Escribir por WhatsApp"
        >
          <span class="w-5 h-5 shrink-0" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </span>
          Escribir por WhatsApp
        </a>
      ) : null}
    </div>
  )}
</section>

<script>
  const replyTo = document.getElementById('contact-replyto') as HTMLInputElement | null;
  const emailInput = document.getElementById('contact-email') as HTMLInputElement | null;
  if (replyTo && emailInput) {
    emailInput.addEventListener('change', () => { replyTo.value = emailInput.value; });
    emailInput.addEventListener('input', () => { replyTo.value = emailInput.value; });
  }
</script>
