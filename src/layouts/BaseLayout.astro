---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { ViewTransitions } from 'astro:transitions';
import { LayoutDashboard, Home, LayoutGrid, Wrench, Users, Mail, Briefcase, Menu, X, Sun, Moon } from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Desarrollo web, apps móviles, landing pages, bases de datos, pasarelas de pago, IA y chatbots. Planes por industria para pymes. Dev Service Plans.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <ViewTransitions />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700&display=swap" rel="stylesheet" />
    <title>{title} | Dev Service Plans</title>
    <script is:inline>
      (function () {
        var k = 'dev-service-plans-theme';
        var s = localStorage.getItem(k);
        var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var isDark = s === 'dark' || (s !== 'light' && d);
        var root = document.documentElement;
        root.classList.toggle('dark', isDark);
        root.setAttribute('data-theme', isDark ? 'dark' : 'light');
        root.style.colorScheme = isDark ? 'dark' : 'light';
      })();
    </script>
    <script is:inline>
      (function () {
        var storageKey = 'dev-service-plans-theme';
        var root = document.documentElement;

        function isDark() {
          return root.getAttribute('data-theme') === 'dark' || root.classList.contains('dark');
        }

        function updateIcons() {
          var dark = isDark();
          document.querySelectorAll('.theme-icon-sun').forEach(function (el) { el.style.display = dark ? 'none' : 'inline'; });
          document.querySelectorAll('.theme-icon-moon').forEach(function (el) { el.style.display = dark ? 'inline' : 'none'; });
        }

        function setTheme(theme) {
          root.classList.toggle('dark', theme === 'dark');
          root.setAttribute('data-theme', theme);
          root.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
          localStorage.setItem(storageKey, theme);
          updateIcons();
        }

        document.addEventListener('click', function (e) {
          if (!e.target || !e.target.closest || !e.target.closest('[data-theme-toggle]')) return;
          setTheme(isDark() ? 'light' : 'dark');
        });

        /* Sincronizar con el tema del sistema/navegador cuando no hay preferencia guardada */
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
          if (localStorage.getItem(storageKey) !== null && localStorage.getItem(storageKey) !== '') return;
          var theme = e.matches ? 'dark' : 'light';
          root.classList.toggle('dark', theme === 'dark');
          root.setAttribute('data-theme', theme);
          root.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
          updateIcons();
        });

        function applyStoredTheme() {
          var s = localStorage.getItem(storageKey);
          var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var isDark = s === 'dark' || (s !== 'light' && d);
          root.classList.toggle('dark', isDark);
          root.setAttribute('data-theme', isDark ? 'dark' : 'light');
          root.style.colorScheme = isDark ? 'dark' : 'light';
          updateIcons();
        }

        function initIcons() {
          updateIcons();
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () { initIcons(); applyStoredTheme(); });
        } else {
          initIcons();
          applyStoredTheme();
        }
        document.addEventListener('astro:page-load', function () { initIcons(); applyStoredTheme(); });
      })();
    </script>
  </head>
  <body class="font-sans">
    <header class="border-b border-neutral-200 dark:border-neutral-800 bg-neutral-100/80 dark:bg-neutral-900/80 backdrop-blur-md sticky top-0 z-20 pt-[env(safe-area-inset-top)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3 sm:py-4 flex justify-between items-center gap-4">
        <a href="/" class="nav-link flex items-center gap-2 text-base sm:text-lg font-semibold text-neutral-900 dark:text-neutral-50 transition-colors truncate min-w-0 py-2 px-2 -mx-2 rounded-lg touch-manipulation">
          <span class="text-neutral-700 dark:text-neutral-400 shrink-0 [&_svg]:stroke-current"><LayoutDashboard size={22} strokeWidth={1.75} /></span>
          <span>Dev Service Plans</span>
        </a>

        <!-- Botón menú móvil -->
        <button
          type="button"
          id="nav-toggle"
          class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-neutral-600 dark:text-neutral-400 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors touch-manipulation"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="nav-menu"
        >
          <Menu id="nav-icon-menu" size={24} strokeWidth={1.75} />
          <X id="nav-icon-close" size={24} strokeWidth={1.75} class="hidden" />
        </button>

        <!-- Nav desktop: enlaces + tema (solo visible en md+) -->
        <nav class="hidden lg:flex items-center gap-1 xl:gap-2 shrink-0" aria-label="Principal">
          <a href="/" class="nav-link flex items-center gap-2 py-2 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Home size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Inicio
          </a>
          <a href="/planes" class="nav-link flex items-center gap-2 py-2 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <LayoutGrid size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Planes
          </a>
          <a href="/#servicios" class="nav-link flex items-center gap-2 py-2 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Wrench size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Servicios
          </a>
          <a href="/sobre-nosotros" class="nav-link flex items-center gap-2 py-2 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Users size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Sobre nosotros
          </a>
          <a href="/#contacto" class="nav-link flex items-center gap-2 py-2 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Mail size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Contacto
          </a>
          <span class="w-px h-5 bg-neutral-300 dark:bg-neutral-600 mx-1" aria-hidden="true" />
          <a href="https://lgomez.dev/projects" target="_blank" rel="noopener noreferrer" class="nav-link flex items-center gap-2 py-2 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Briefcase size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Portafolio
          </a>
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <!-- Overlay y panel móvil FUERA del header para que el z-index funcione sobre main -->
    <div
      id="nav-overlay"
      class="fixed inset-0 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200 lg:hidden"
      style="z-index: 9998;"
      aria-hidden="true"
    />
    <nav
      id="nav-menu"
      class="fixed top-0 right-0 h-full w-[min(100%,18rem)] bg-neutral-100 dark:bg-neutral-900 border-l border-neutral-200 dark:border-neutral-800 shadow-xl flex flex-col pt-[env(safe-area-inset-top)] translate-x-full transition-transform duration-200 ease-out lg:hidden min-h-0"
      style="z-index: 9999;"
      aria-label="Menú móvil"
    >
      <div class="flex justify-end p-4 pb-2 shrink-0">
        <button type="button" id="nav-close" class="w-10 h-10 flex items-center justify-center rounded-lg text-neutral-600 dark:text-neutral-400 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors" aria-label="Cerrar menú">
          <X size={24} strokeWidth={1.75} />
        </button>
      </div>
      <ul class="flex flex-col gap-1 px-4 pb-6 overflow-y-auto min-h-0 flex-1 touch-pan-y">
        <li>
          <a href="/" class="nav-link flex items-center gap-2 py-3 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Home size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Inicio
          </a>
        </li>
        <li>
          <a href="/planes" class="nav-link flex items-center gap-2 py-3 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <LayoutGrid size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Planes
          </a>
        </li>
        <li>
          <a href="/#servicios" class="nav-link flex items-center gap-2 py-3 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Wrench size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Servicios
          </a>
        </li>
        <li>
          <a href="/sobre-nosotros" class="nav-link flex items-center gap-2 py-3 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Users size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Sobre nosotros
          </a>
        </li>
        <li>
          <a href="/#contacto" class="nav-link flex items-center gap-2 py-3 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Mail size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Contacto
          </a>
        </li>
        <li>
          <a href="https://lgomez.dev/projects" target="_blank" rel="noopener noreferrer" class="nav-link flex items-center gap-2 py-3 px-3 rounded-lg text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation">
            <Briefcase size={18} strokeWidth={1.75} class="shrink-0 [&_svg]:stroke-current" />
            Portafolio
          </a>
        </li>
      </ul>
      <div class="pt-4 px-4 border-t border-neutral-200 dark:border-neutral-800 shrink-0">
        <button
          type="button"
          data-theme-toggle
          aria-label="Cambiar tema (claro/oscuro)"
          class="nav-link theme-toggle-btn flex items-center gap-2 py-3 px-3 rounded-lg w-full text-left text-sm font-medium text-neutral-600 dark:text-neutral-400 transition-colors touch-manipulation"
        >
          <span class="theme-icon-sun shrink-0 [&_svg]:stroke-current" aria-hidden="true" style="display: none;">
            <Sun size={18} strokeWidth={1.75} />
          </span>
          <span class="theme-icon-moon shrink-0 [&_svg]:stroke-current" aria-hidden="true" style="display: none;">
            <Moon size={18} strokeWidth={1.75} />
          </span>
          <span>Tema</span>
        </button>
      </div>
    </nav>

    <script is:inline>
      (function () {
        function getEls() {
          return {
            toggle: document.getElementById('nav-toggle'),
            menu: document.getElementById('nav-menu'),
            overlay: document.getElementById('nav-overlay'),
            iconMenu: document.getElementById('nav-icon-menu'),
            iconClose: document.getElementById('nav-icon-close')
          };
        }

        function openMenu() {
          var e = getEls();
          if (!e.menu || !e.overlay) return;
          e.menu.classList.remove('translate-x-full');
          e.overlay.classList.remove('opacity-0', 'pointer-events-none');
          e.overlay.classList.add('opacity-100', 'pointer-events-auto');
          if (e.iconMenu) e.iconMenu.classList.add('hidden');
          if (e.iconClose) e.iconClose.classList.remove('hidden');
          if (e.toggle) { e.toggle.setAttribute('aria-expanded', 'true'); e.toggle.setAttribute('aria-label', 'Cerrar menú'); }
        }

        function closeMenu() {
          var e = getEls();
          if (!e.menu || !e.overlay) return;
          e.menu.classList.add('translate-x-full');
          e.overlay.classList.add('opacity-0', 'pointer-events-none');
          e.overlay.classList.remove('opacity-100', 'pointer-events-auto');
          if (e.iconMenu) e.iconMenu.classList.remove('hidden');
          if (e.iconClose) e.iconClose.classList.add('hidden');
          if (e.toggle) { e.toggle.setAttribute('aria-expanded', 'false'); e.toggle.setAttribute('aria-label', 'Abrir menú'); }
        }

        function onBodyClick(ev) {
          var target = ev.target;
          if (!target || !target.closest) return;
          if (target.closest('#nav-toggle')) {
            ev.preventDefault();
            var menu = document.getElementById('nav-menu');
            if (menu && menu.classList.contains('translate-x-full')) openMenu();
            else closeMenu();
            return;
          }
          if (target.closest('#nav-close') || target.closest('#nav-overlay')) {
            ev.preventDefault();
            closeMenu();
            return;
          }
          if (window.innerWidth < 1024 && target.closest('#nav-menu a')) {
            closeMenu();
          }
        }

        function initNavMenu() {
          document.body.removeEventListener('click', onBodyClick);
          document.body.addEventListener('click', onBodyClick);
          closeMenu();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initNavMenu);
        } else {
          initNavMenu();
        }
        document.addEventListener('astro:page-load', initNavMenu);
      })();
    </script>

    <main class="flex-1 w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 lg:py-14 pb-[calc(2rem+env(safe-area-inset-bottom))] sm:pb-12">
      <slot />
    </main>

    <WhatsAppFloat />

    <footer class="border-t border-neutral-200 dark:border-neutral-800 bg-neutral-100/60 dark:bg-neutral-900/60 mt-auto pb-[env(safe-area-inset-bottom)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-6 text-center">
        <p class="text-xs sm:text-sm text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto">
          © {new Date().getFullYear()} Dev Service Plans. Planes de desarrollo freelance por industria.
          <a href="https://lgomez.dev/projects" target="_blank" rel="noopener noreferrer" class="text-neutral-700 dark:text-neutral-400 hover:underline ml-1">Portafolio</a>
        </p>
      </div>
    </footer>
  </body>
</html>
